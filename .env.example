# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=your-supabase-url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# İyzico Payment Gateway Configuration
# Sandbox (Test Environment)
IYZICO_API_KEY=your-sandbox-api-key
IYZICO_SECRET_KEY=your-sandbox-secret-key
IYZICO_BASE_URL=https://sandbox-api.iyzipay.com

# Production (Live Environment) - Uncomment when ready for production
# IYZICO_API_KEY=your-production-api-key
# IYZICO_SECRET_KEY=your-production-secret-key
# IYZICO_BASE_URL=https://api.iyzipay.com

# SMS Configuration (Optional - for SMS features)
SMS_API_KEY=your-sms-api-key

# Admin Configuration
ADMIN_EMAIL=your-admin-email@example.com

# Application URL
NEXT_PUBLIC_APP_URL=http://localhost:3000
